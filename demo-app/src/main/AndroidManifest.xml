<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml لتطبيق Atheer Demo
    يحتوي على إعلانات الأنشطة والصلاحيات اللازمة
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- صلاحية NFC -->
    <uses-permission android:name="android.permission.NFC" />
    <!-- صلاحيات الشبكة -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- صلاحية الاهتزاز -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- صلاحية البيومترية -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- NFC اختياري حتى يعمل التطبيق على أجهزة بدون NFC -->
    <uses-feature android:name="android.hardware.nfc" android:required="false" />
    <uses-feature android:name="android.hardware.nfc.hce" android:required="false" />

    <application
        android:name=".AtheerDemoApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AtheerDemo">

        <!-- شاشة البداية (Splash) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AtheerDemo.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- شاشة تسجيل الدخول -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- لوحة التحكم: اختيار المسار -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false" />

        <!-- الشاشة الرئيسية للعميل -->
        <activity
            android:name=".ui.customer.CustomerMainActivity"
            android:exported="false" />

        <!-- الشاشة الرئيسية للتاجر -->
        <activity
            android:name=".ui.merchant.MerchantMainActivity"
            android:exported="false" />

        <!-- مسار العميل: محاكاة البطاقة (HCE) -->
        <activity
            android:name=".ui.customer.CustomerActivity"
            android:exported="false" />

        <!-- مسار نقطة المبيعات (SoftPOS) -->
        <activity
            android:name=".ui.pos.PosActivity"
            android:exported="false" />

        <!-- شاشة نتيجة المعاملة -->
        <activity
            android:name=".ui.result.TransactionResultActivity"
            android:exported="false" />

        <!-- شاشة نجاح الدفع (شفافة) -->
        <activity
            android:name=".ui.payment.PaymentSuccessActivity"
            android:exported="false"
            android:theme="@style/Theme.AtheerDemo.Translucent" />

        <!-- خدمة HCE (Host Card Emulation) لـ Atheer SDK — مطلوبة لعمل NFC في مسار العميل -->
        <service
            android:name="com.atheer.sdk.hce.AtheerHceService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/atheer_apdu_service" />
        </service>

    </application>

</manifest>

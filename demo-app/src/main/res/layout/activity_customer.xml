<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_customer.xml
    شاشة مسار العميل: محاكاة بطاقة NFC (HCE)
    يسمح للمستخدم بتجهيز الدفع ثم اقتراب الهاتف من القارئ
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <!-- شريط أعلى الصفحة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_customer"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="back"
            android:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/customer_title"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_credit_card"
            android:contentDescription="icon"
            android:tint="@color/white" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- قسم إدخال بيانات الدفع -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بيانات الدفع"
                        android:textColor="@color/atheer_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- حقل المبلغ -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAmount"
                        style="@style/Widget.AtheerDemo.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/hint_amount">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:inputType="number"
                            android:imeOptions="actionNext"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- حقل رقم البطاقة -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCardNumber"
                        style="@style/Widget.AtheerDemo.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_card_number">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCardNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:inputType="number"
                            android:maxLength="16"
                            android:imeOptions="actionDone"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- زر تجهيز الدفع -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreparePayment"
                        style="@style/Widget.AtheerDemo.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/btn_prepare_payment" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- قسم حالة NFC -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- أيقونة NFC المتحركة -->
                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:background="@drawable/bg_nfc_circle">

                        <ImageView
                            android:id="@+id/ivNfcIcon"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nfc"
                            android:contentDescription="NFC"
                            android:alpha="0.5" />

                    </FrameLayout>

                    <!-- حالة NFC -->
                    <TextView
                        android:id="@+id/tvNfcStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/hce_status_idle"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:gravity="center" />

                    <!-- رسالة الإرشاد -->
                    <TextView
                        android:id="@+id/tvNfcGuide"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/customer_nfc_tap"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>

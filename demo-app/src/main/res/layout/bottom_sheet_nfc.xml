<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_nfc.xml
    BottomSheet يعرض أنيميشن NFC بعد المصادقة البيومترية
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:layoutDirection="rtl">

    <!-- أيقونة NFC متحركة -->
    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_nfc_circle">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nfc"
            android:contentDescription="NFC"
            android:tint="@color/atheer_primary" />

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/nfc_ready_to_pay"
        android:textColor="@color/atheer_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/nfc_tap_instruction"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center" />

    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/atheer_primary" />

</LinearLayout>
